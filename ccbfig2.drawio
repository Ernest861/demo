        <!-- Legend / Notes -->
        <mxCell id="legend" value="Blue: Weakened top-down control&#xa;Red: Hyperactive stress/reinforcement circuits&#xa;Adapted from Koob &amp; Volkow (2016), de Guglielmo et al. (2019), Cao et al. (2025)" style="text;html=1;align=left;verticalAlign=top;fontSize=9;fontColor=#455A64;whiteSpace=wrap;" vertex="1" parent="1">
