          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        
        <!-- Extended Amygdala → Downstream (stress output) -->
        <mxCell id="arrow5" value="→ Defensive &amp; Autonomic Responses" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=1;exitY=0.8;entryX=0;entryY=0.5;strokeColor=#455A64;strokeWidth=2;endArrow=classic;fontSize=10;" edge="1" parent="1" source="BNST" target="Hypothalamus">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        
        <!-- Feedback: Negative Reinforcement Loop -->
        <mxCell id="loop" value="Negative Reinforcement&lt;br&gt;(Hyperkatifeia → Compulsive Seeking)" style="edgeStyle=loopEdgeStyle;rounded=1;html=1;exitX=0.9;exitY=0.9;entryX=0.8;entryY=1.1;strokeColor=#EF5350;strokeWidth=2;dashed=1;endArrow=classic;fontSize=10;labelBackgroundColor=#FFEBEE;" edge="1" parent="1" source="NAc" target="CeA">
          <mxGeometry relative="1" as="geometry">
