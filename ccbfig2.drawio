          <mxGeometry x="580" y="340" width="160" height="70" as="geometry"/>
        </mxCell>
        
        <!-- Connections (Arrows) -->
        <!-- mPFC → BLA (weakened) -->
        <mxCell id="arrow1" value="glutamatergic (↓ in addiction)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.3;strokeColor=#2C6EB0;strokeWidth=2;dashed=1;endArrow=classic;labelBackgroundColor=#ffffff;fontSize=10;" edge="1" parent="1" source="mPFC" target="BLA">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        
        <!-- BLA → CeA -->
        <mxCell id="arrow2" value="BLA → CeA" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=1;exitY=0.7;entryX=0;entryY=0.4;strokeColor=#6B4C9C;strokeWidth=3;endArrow=classic;fontSize=11;" edge="1" parent="1" source="BLA" target="CeA">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        
        <!-- CeA ↔ BNST (CRF pathway) -->
        <mxCell id="arrow3" value="CRF-dependent&lt;br&gt;amygdalofugal pathway" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=0.8;exitY=1;entryX=0.5;entryY=0;strokeColor=#D32F2F;strokeWidth=3;endArrow=classic;startArrow=classic;fontSize=10;" edge="1" parent="1" source="CeA" target="BNST">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        
        <!-- CeA/BNST → NAc Shell -->
