      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        
        <!-- Title -->
        <mxCell id="title" value="Figure 1. The Extended Amygdala as a Driver of Compulsive Drug Seeking in Addiction" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=16;fontStyle=1;fontFamily=Arial" vertex="1" parent="1">
          <mxGeometry x="50" y="20" width="750" height="40" as="geometry"/>
        </mxCell>
        
        <!-- Brain Regions -->
        <!-- mPFC (Prefrontal Control - weakened) -->
        <mxCell id="mPFC" value="mPFC&lt;br&gt;(Prefrontal Cortex)&lt;br&gt;↓ Top-down Control" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E6F0FA;strokeColor=#2C6EB0;fontColor=#1A3A6E;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="80" y="100" width="140" height="90" as="geometry"/>
        </mxCell>
        
        <!-- BLA -->
        <mxCell id="BLA" value="BLA&lt;br&gt;(Basolateral Amygdala)&lt;br&gt;Glutamatergic Input" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F0E6FA;strokeColor=#6B4C9C;fontColor=#3C2A5E;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="280" y="80" width="130" height="80" as="geometry"/>
        </mxCell>
        
        <!-- Extended Amygdala Core (highlight in red tone) -->
        <mxCell id="EA_box" value="" style="rounded=1;fillColor=#FFF0F0;strokeColor=#D32F2F;strokeWidth=3;opacity=80;" vertex="1" parent="1">
          <mxGeometry x="260" y="200" width="320" height="220" as="geometry"/>
        </mxCell>
        
        <!-- CeA -->
        <mxCell id="CeA" value="CeA&lt;br&gt;(Central Amygdala)&lt;br&gt;CRF↑ + Dynorphin↑&lt;br&gt;GABAergic Output" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFEBEE;strokeColor=#C62828;fontColor=#B71C1C;fontSize=12;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="300" y="220" width="140" height="95" as="geometry"/>
        </mxCell>
        
        <!-- BNST -->
        <mxCell id="BNST" value="BNST&lt;br&gt;(Bed Nucleus of the Stria Terminalis)&lt;br&gt;Stress Amplification" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFEBEE;strokeColor=#C62828;fontColor=#B71C1C;fontSize=12;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="300" y="330" width="140" height="80" as="geometry"/>
        </mxCell>
        
        <!-- NAc Shell -->
